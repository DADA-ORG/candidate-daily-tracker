# 飞书自建应用凭证（在 https://open.feishu.cn 创建，需开通"获取与发送单聊、群组消息"权限）
LARK_APP_ID=
LARK_APP_SECRET=

# 姓名对照表所在的飞书多维表格（Bitable）
# App Token 和 Table ID 可以从表格链接里截取：
# https://xxx.feishu.cn/base/{APP_TOKEN}?table={TABLE_ID}
LARK_BITABLE_APP_TOKEN=
LARK_BITABLE_TABLE_ID=

# 对照表里的字段名（按你实际表格的列名填）
LARK_BITABLE_NAME_FIELD=姓名
LARK_BITABLE_USER_FIELD=关联人员
