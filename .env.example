# 飞书/Lark 自建应用凭证
LARK_APP_ID=
LARK_APP_SECRET=

# API 域名：这个项目对接的是国际版 Lark Suite（dadaconsultants.sg.larksuite.com），
# 默认已经是 open.larksuite.com，不用改。如果以后换成国内飞书租户，改成 https://open.feishu.cn
LARK_API_BASE_URL=https://open.larksuite.com

# 姓名对照表：直接从多维表格链接里截取
# https://dadaconsultants.sg.larksuite.com/base/{APP_TOKEN}?table={TABLE_ID}
LARK_BITABLE_APP_TOKEN=TyJYbQNpha75WCsQMIJlkbL5grf

# 如果对照表改成从知识库 Wiki 页面打开（链接形如 .../wiki/{WIKI_TOKEN}?table=...），
# 把 LARK_BITABLE_APP_TOKEN 留空，填这个，代码会自动解析出真正的 app_token。
LARK_WIKI_TOKEN=

# 对照表所在数据表的 Table ID（链接里 table= 后面那一段）
LARK_BITABLE_TABLE_ID=tblsCuaKpDO72toQ

# 对照表里的字段名：
# "GULU Account Name" 是纯文本列，存的是 "Frayzer Lou" 这种格式，跟 Excel User 列写法一致，用来匹配。
# "Name" 是人员类型字段（自带 email/id/name），用来取 open_id。
LARK_BITABLE_NAME_FIELD=GULU Account Name
LARK_BITABLE_USER_FIELD=Name
